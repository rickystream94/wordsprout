# PROD environment variables for WordSprout frontend
# Copy this file to .env.prod (gitignored) and fill in the values.
# Run: vite build --mode prod  (or: npm run build -- --mode prod)
# In GitHub Actions these values are injected as environment variables from GitHub Actions Variables.

VITE_APP_ENV=prod

# Microsoft Entra ID — PROD app registration
# Client ID of the wordsprout-prod app registration (output of setup-entra-apps.ps1)
VITE_ENTRA_CLIENT_ID=

# Google OAuth 2.0 — PROD client (from Google Cloud Console)
# Authorized JavaScript origins must include the PROD SWA URL (and custom domain when configured).
VITE_GOOGLE_CLIENT_ID=

# MSAL redirect URI — must match a redirect URI in the wordsprout-prod app registration
VITE_REDIRECT_URI=

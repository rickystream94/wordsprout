# DEV environment variables for WordSprout frontend
# Copy this file to .env.dev (gitignored) and fill in the values.
# Run: vite build --mode dev  (or: npm run build -- --mode dev)

VITE_APP_ENV=dev

# Microsoft Entra ID — DEV app registration
# Client ID of the wordsprout-dev app registration (output of setup-entra-apps.ps1)
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=

# Google OAuth 2.0 — DEV client (from Google Cloud Console)
# Authorized JavaScript origins must include http://localhost:5173 and the DEV SWA URL.
VITE_GOOGLE_CLIENT_ID=

# MSAL redirect URI — must match a redirect URI in the wordsprout-dev app registration
# Defaults to window.location.origin at runtime if left empty
VITE_REDIRECT_URI=
